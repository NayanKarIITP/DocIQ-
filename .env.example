# ─── Google Gemini ────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_EMBED_MODEL=embedding-001

# ─── Qdrant Vector Store ──────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=multimodal_rag

# ─── PostgreSQL (Feedback Loop) ───────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@localhost:5432/ragdb

# ─── App Settings ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
